# Claude Code session/local data
.claude/

# Rust build artifacts
/target/
# nested target/ dirs for workspace-excluded crates (e.g. crates/sh-wasm) — never commit
**/target/
**/*.rs.bk

# cargo-fuzz build dirs + generated corpora/artifacts (never commit — they are
# build output, and the binaries bloat the repo). Applies to every crate's fuzz/.
**/fuzz/target/
**/fuzz/corpus/
**/fuzz/artifacts/

# OS / editor cruft
.DS_Store
*.swp

# stray scratch build output (e.g. rustc -o rust_out)
/rust_out
